<Window x:Class="ClaudeUsageMonitor.App.Inquiry.InquiryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="문의하기 — Agent Usage Monitor"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
  </Window.Resources>

  <StackPanel Margin="24,20">
    <TextBlock Text="문의하기" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
    <TextBlock Text="버그 신고, 기능 제안 등 무엇이든 보내주세요. 앱 버전 정보가 함께 전송됩니다."
               FontSize="11" Opacity="0.6" Margin="0,0,0,14" TextWrapping="Wrap"/>

    <TextBlock Text="분류" Style="{StaticResource SectionLabel}"/>
    <ComboBox SelectedIndex="{Binding CategoryIndex}" Width="170" HorizontalAlignment="Left"
              Style="{StaticResource AppComboBox}" Margin="0,0,0,14">
      <ComboBoxItem Content="버그제보"/>
      <ComboBoxItem Content="개선요청"/>
    </ComboBox>

    <TextBlock Text="제목" Style="{StaticResource SectionLabel}"/>
    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
             Style="{StaticResource AppTextBox}" Margin="0,0,0,14"/>

    <TextBlock Text="내용" Style="{StaticResource SectionLabel}"/>
    <TextBox Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
             Style="{StaticResource AppTextBox}"
             AcceptsReturn="True" TextWrapping="Wrap"
             VerticalScrollBarVisibility="Auto"
             VerticalContentAlignment="Top"
             Height="180" Margin="0,0,0,16"/>

    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Button Grid.Column="0" Content="전송" Command="{Binding SendCommand}"
              Style="{StaticResource AccentButton}" MinWidth="88"/>
      <TextBlock Grid.Column="1" Text="{Binding StatusText}" Margin="12,0,0,0" FontSize="11"
                 VerticalAlignment="Center" Foreground="#7BD88F" TextWrapping="Wrap"/>
    </Grid>
  </StackPanel>
</Window>
