<Window x:Class="ClaudeUsageMonitor.App.Settings.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="설정 — Agent Usage Monitor"
        Width="480" SizeToContent="Height"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterOwner">
  <Window.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- 설정 행: 좌 라벨(+설명) / 우 컨트롤 -->
    <Style x:Key="RowLabel" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
      <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style x:Key="RowHint" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Opacity" Value="0.55"/>
      <Setter Property="TextWrapping" Value="Wrap"/>
      <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>
  </Window.Resources>

  <StackPanel Margin="24,20,24,20">
    <TextBlock Text="설정" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

    <!-- 모니터링 -->
    <TextBlock Text="모니터링" Style="{StaticResource SectionLabel}"/>
    <Border Style="{StaticResource SectionCard}">
      <StackPanel>
        <Grid Margin="0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock Text="새로고침 주기 (초)" Style="{StaticResource RowLabel}"/>
            <TextBlock Text="최소 20초 — 60초 미만은 API 제한(429) 위험이 커집니다" Style="{StaticResource RowHint}"/>
          </StackPanel>
          <TextBox Grid.Column="1" Width="90"
                   Text="{Binding PollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                   Style="{StaticResource AppTextBox}"/>
        </Grid>

        <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,2"/>

        <Grid Margin="0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock Text="5시간 사용량 경고 알림" Style="{StaticResource RowLabel}"/>
            <TextBlock Text="임계값 도달 시 트레이 풍선 알림 1회 (리셋·재시작·계정 변경 시 재무장)"
                       Style="{StaticResource RowHint}"/>
          </StackPanel>
          <CheckBox x:Name="WarnToggle" Grid.Column="1" IsChecked="{Binding WarnNotificationEnabled}"/>
        </Grid>

        <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,2"/>

        <Grid Margin="0,10" IsEnabled="{Binding WarnNotificationEnabled}">
          <Grid.Style>
            <Style TargetType="Grid">
              <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Opacity" Value="0.45"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </Grid.Style>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock Text="5시간 경고 임계값" Style="{StaticResource RowLabel}"/>
            <TextBlock Text="이 사용률에 도달하면 알림" Style="{StaticResource RowHint}"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal">
            <Slider Value="{Binding WarnThresholdPct}" Minimum="50" Maximum="99"
                    Width="150" TickFrequency="5" IsSnapToTickEnabled="True"
                    VerticalAlignment="Center"/>
            <TextBlock Text="{Binding WarnThresholdPct, StringFormat={}{0:0}%}" Margin="10,0,0,0"
                       FontWeight="Bold" MinWidth="34"/>
          </StackPanel>
        </Grid>

        <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,2"/>

        <Grid Margin="0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock Text="한도 소진 예측 표시" Style="{StaticResource RowLabel}"/>
            <TextBlock Text="최근 사용 속도로 5시간 한도 도달 시점을 위젯·대시보드에 표시"
                       Style="{StaticResource RowHint}"/>
          </StackPanel>
          <CheckBox Grid.Column="1" IsChecked="{Binding ShowExhaustionPrediction}"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- 표시 -->
    <TextBlock Text="표시" Style="{StaticResource SectionLabel}"/>
    <Border Style="{StaticResource SectionCard}">
      <StackPanel>
        <Grid Margin="0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="테마" Style="{StaticResource RowLabel}"/>
          <ComboBox Grid.Column="1" Width="170" SelectedIndex="{Binding ThemeIndex}"
                    Style="{StaticResource AppComboBox}">
            <ComboBoxItem Content="다크"/>
            <ComboBoxItem Content="라이트"/>
            <ComboBoxItem Content="시스템 설정 따름"/>
          </ComboBox>
        </Grid>

        <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,2"/>

        <Grid Margin="0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock Text="표시 모드" Style="{StaticResource RowLabel}"/>
            <TextBlock Text="작업표시줄 도킹 시 드래그로 위치 이동 가능" Style="{StaticResource RowHint}"/>
          </StackPanel>
          <ComboBox Grid.Column="1" Width="170" SelectedIndex="{Binding ModeIndex}"
                    Style="{StaticResource AppComboBox}">
            <ComboBoxItem Content="작업표시줄 도킹"/>
            <ComboBoxItem Content="플로팅"/>
            <ComboBoxItem Content="숨김"/>
          </ComboBox>
        </Grid>

        <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,2"/>

        <Grid Margin="0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
            <TextBlock Text="작업표시줄 내장(임베드)" Style="{StaticResource RowLabel}"/>
            <TextBlock Text="위젯을 작업표시줄 창 내부에 넣어 시작 메뉴·플라이아웃이 열려도 가려지지 않습니다. 표시 문제가 생기면 끄세요 (기존 방식으로 동작)"
                       Style="{StaticResource RowHint}"/>
          </StackPanel>
          <CheckBox x:Name="EmbedToggle" Grid.Column="1" IsChecked="{Binding TaskbarEmbedEnabled}"/>
        </Grid>

        <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,2"/>

        <Grid Margin="0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Windows 시작 시 실행" Style="{StaticResource RowLabel}"/>
          <CheckBox Grid.Column="1" IsChecked="{Binding AutoStart}"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- 업데이트 -->
    <TextBlock Text="업데이트" Style="{StaticResource SectionLabel}"/>
    <Border Style="{StaticResource SectionCard}">
      <StackPanel>
        <Grid Margin="0,10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="현재 버전 " Style="{StaticResource RowLabel}"/>
              <TextBlock Text="{Binding CurrentVersionText}" Style="{StaticResource RowLabel}"
                         FontFamily="{StaticResource MonoFont}" FontWeight="Bold"/>
            </StackPanel>
            <TextBlock Text="새 버전은 4시간마다 자동 확인되며, 발견 시 위젯 우클릭 메뉴에도 표시됩니다"
                       Style="{StaticResource RowHint}"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Button Content="업데이트 확인" Command="{Binding CheckUpdateCommand}"
                    Style="{StaticResource AppButton}"/>
            <Button Command="{Binding InstallUpdateCommand}" Margin="8,0,0,0"
                    Content="{Binding UpdateVersionText}" ContentStringFormat="v{0} 설치">
              <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding UpdateVersionText}" Value="">
                      <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Button.Style>
            </Button>
          </StackPanel>
        </Grid>
        <TextBlock Text="{Binding UpdateStatusText}" FontSize="11" Margin="0,0,0,8"
                   Foreground="{DynamicResource PredictionBrush}">
          <TextBlock.Style>
            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding UpdateStatusText}" Value="">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
        <!-- 메이저 버전 업그레이드: 인앱 설치 차단 — 수동 다운로드 안내 (AGPL 링크와 동일 핸들러) -->
        <TextBlock FontSize="11" Margin="0,0,0,8" TextWrapping="Wrap">
          <TextBlock.Style>
            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
              <Style.Triggers>
                <DataTrigger Binding="{Binding MajorUpdateVersion}" Value="">
                  <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
          <Run Text="새 주요 버전 v"/><Run Text="{Binding MajorUpdateVersion, Mode=OneWay}" FontWeight="Bold"/><Run Text=" &#x2014; 설치 방식이 달라 수동 설치가 필요합니다. "/><Hyperlink NavigateUri="{Binding ReleasesPageUri}"
                     RequestNavigate="OnSourceLinkNavigate">GitHub 릴리스에서 다운로드</Hyperlink>
        </TextBlock>
      </StackPanel>
    </Border>

    <!-- 푸터 -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Button x:Name="SaveButton" Grid.Column="0" Content="저장" Command="{Binding SaveCommand}"
              Style="{StaticResource AccentButton}" MinWidth="88"/>
      <Button Grid.Column="1" Content="데이터 폴더 열기" Command="{Binding OpenDataFolderCommand}"
              Style="{StaticResource AppButton}" Margin="10,0,0,0"/>
      <TextBlock Grid.Column="2" Text="{Binding StatusText}" Margin="12,0,0,0" FontSize="11"
                 Foreground="#7BD88F" HorizontalAlignment="Right"/>
    </Grid>

    <!-- 법적 고지 (AGPL-3.0 §5(d): 대화형 UI는 저작권·라이선스·소스 위치를 표시) -->
    <Border Height="1" Background="{DynamicResource CardBorderBrush}" Margin="0,16,0,10"/>
    <TextBlock FontSize="10" Foreground="{DynamicResource TextPrimaryBrush}"
               TextWrapping="Wrap" Opacity="0.65">
      <Run Text="© 2026 WeaverLoft inc. AILabs · GNU AGPL-3.0 · 소스: "/><Hyperlink NavigateUri="https://github.com/Weaverloft-AILabs/Agent-Usage-Monitor-Win"
                 RequestNavigate="OnSourceLinkNavigate">github.com/Weaverloft-AILabs/Agent-Usage-Monitor-Win</Hyperlink>
    </TextBlock>
  </StackPanel>
</Window>
