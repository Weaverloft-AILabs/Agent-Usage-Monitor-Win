<UserControl x:Class="ClaudeUsageMonitor.App.Widget.GaugeBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Orientation="Horizontal" Margin="8,3" VerticalAlignment="Center">
    <TextBlock x:Name="LabelText" FontSize="11" FontWeight="Bold" Foreground="#DDFFFFFF"
               VerticalAlignment="Center" Margin="0,0,6,0"/>
    <Grid Width="72" Height="10" VerticalAlignment="Center">
      <Border Background="#2EFFFFFF" CornerRadius="5"/>
      <Border x:Name="Fill" HorizontalAlignment="Left" CornerRadius="5" Width="0"/>
    </Grid>
    <TextBlock x:Name="PercentText" FontSize="11" FontWeight="SemiBold" Foreground="#EEFFFFFF"
               VerticalAlignment="Center" Margin="6,0,0,0" MinWidth="30"/>
    <TextBlock x:Name="ResetTextBlock" FontSize="10" Foreground="#88FFFFFF"
               VerticalAlignment="Center" Margin="4,0,0,0"/>
  </StackPanel>
</UserControl>
