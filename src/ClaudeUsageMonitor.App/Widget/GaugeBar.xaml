<UserControl x:Class="ClaudeUsageMonitor.App.Widget.GaugeBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <StackPanel Orientation="Horizontal" Margin="6,1" VerticalAlignment="Center">
    <TextBlock x:Name="LabelText" FontSize="10" FontWeight="Bold"
               Foreground="{DynamicResource WidgetTextBrush}"
               VerticalAlignment="Center" Margin="0,0,5,0" MinWidth="18"/>
    <Grid Width="56" Height="7" VerticalAlignment="Center">
      <Border Background="{DynamicResource GaugeTrackBrush}" CornerRadius="3.5"/>
      <Border x:Name="Fill" HorizontalAlignment="Left" CornerRadius="3.5" Width="0"/>
    </Grid>
    <TextBlock x:Name="PercentText" FontSize="10" FontWeight="SemiBold"
               Foreground="{DynamicResource WidgetTextStrongBrush}"
               VerticalAlignment="Center" Margin="5,0,0,0" MinWidth="26"/>
    <TextBlock x:Name="ResetTextBlock" FontSize="9"
               Foreground="{DynamicResource WidgetTextDimBrush}"
               VerticalAlignment="Center" Margin="3,0,0,0" MinWidth="34"/>
    <TextBlock x:Name="PredictionTextBlock" FontSize="9" FontWeight="SemiBold"
               Foreground="{DynamicResource PredictionBrush}"
               VerticalAlignment="Center" Margin="4,0,0,0" Visibility="Collapsed"/>
  </StackPanel>
</UserControl>
