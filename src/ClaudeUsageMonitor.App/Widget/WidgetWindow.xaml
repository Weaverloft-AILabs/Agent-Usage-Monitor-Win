<Window x:Class="ClaudeUsageMonitor.App.Widget.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widget="clr-namespace:ClaudeUsageMonitor.App.Widget"
        Title="Agent Usage Monitor Widget"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
  </Window.Resources>
  <Border Background="{DynamicResource WidgetBackgroundBrush}" CornerRadius="6"
          BorderBrush="{DynamicResource WidgetBorderBrush}" BorderThickness="1"
          Padding="2,1">
    <StackPanel Orientation="Horizontal">
      <!-- Claude Code CLI 미감지 경고 — 게이지 대신 표시, 로그인 감지 시 자동 복구 -->
      <TextBlock Text="⚠ Claude Code 미감지" FontSize="12" FontWeight="SemiBold"
                 Foreground="#F0A030" VerticalAlignment="Center" Margin="6,0"
                 Visibility="{Binding CliMissing, Converter={StaticResource BoolToVis}}"
                 ToolTip="Claude Code CLI가 설치되어 있지 않거나 로그인 정보를 읽을 수 없습니다.&#10;claude 명령으로 로그인하면 자동으로 복구됩니다."/>
      <!-- 5시간/주간 각 1줄, 세로 2줄 (작업표시줄 높이 안에 맞춤) -->
      <StackPanel Orientation="Vertical">
        <StackPanel.Style>
          <Style TargetType="StackPanel">
            <Style.Triggers>
              <DataTrigger Binding="{Binding CliMissing}" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </StackPanel.Style>
        <widget:GaugeBar x:Name="FiveHourGauge" Label="5H"
                         Percent="{Binding FiveHourPct}"
                         BarBrush="{Binding FiveHourBrush}"
                         ResetText="{Binding FiveHourResetText}"
                         PredictionText="{Binding ExhaustionText}"
                         ToolTip="소진 예측: 최근 사용 속도 기준 5시간 한도(100%) 도달까지 남은 시간"/>
        <widget:GaugeBar x:Name="SevenDayGauge" Label="7D"
                         Percent="{Binding SevenDayPct}"
                         BarBrush="{Binding SevenDayBrush}"
                         ResetText="{Binding SevenDayResetText}"/>
      </StackPanel>
      <!-- 새 버전 알림 아이콘 (우클릭 메뉴에서 설치) -->
      <TextBlock Text="⬆" FontSize="13" FontWeight="Bold"
                 Foreground="{DynamicResource PredictionBrush}"
                 VerticalAlignment="Center" Margin="2,0,4,0"
                 Visibility="{Binding UpdateAvailable, Converter={StaticResource BoolToVis}}"
                 ToolTip="{Binding UpdateBadgeToolTip}"/>
    </StackPanel>
  </Border>
</Window>
