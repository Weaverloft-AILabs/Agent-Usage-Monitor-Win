<Window x:Class="ClaudeUsageMonitor.App.Widget.WidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widget="clr-namespace:ClaudeUsageMonitor.App.Widget"
        Title="Claude Usage"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        SizeToContent="WidthAndHeight">
  <Border Background="#D91C1E28" CornerRadius="6" BorderBrush="#33FFFFFF" BorderThickness="1"
          Padding="2,1">
    <!-- 5시간/주간 각 1줄, 세로 2줄 (작업표시줄 높이 안에 맞춤) -->
    <StackPanel Orientation="Vertical">
      <widget:GaugeBar x:Name="FiveHourGauge" Label="5H"
                       Percent="{Binding FiveHourPct}"
                       BarBrush="{Binding FiveHourBrush}"
                       ResetText="{Binding FiveHourResetText}"/>
      <widget:GaugeBar x:Name="SevenDayGauge" Label="7D"
                       Percent="{Binding SevenDayPct}"
                       BarBrush="{Binding SevenDayBrush}"
                       ResetText="{Binding SevenDayResetText}"/>
    </StackPanel>
  </Border>
</Window>
