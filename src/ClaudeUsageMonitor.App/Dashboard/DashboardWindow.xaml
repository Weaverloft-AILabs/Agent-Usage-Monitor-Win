<Window x:Class="ClaudeUsageMonitor.App.Dashboard.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="Claude Usage Monitor"
        Width="820" Height="600"
        MinWidth="700" MinHeight="500"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="12,8"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
    </Style>
    <!-- 값이 빈 문자열이면 숨김 -->
    <Style x:Key="HideWhenEmpty" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
      <Style.Triggers>
        <Trigger Property="Text" Value="">
          <Setter Property="Visibility" Value="Collapsed"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- 상단: 게이지 + 플랜 + 버튼 -->
    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="5시간 사용률" FontSize="12" Opacity="0.7"/>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding FiveHourPct, StringFormat={}{0:0}%}" FontSize="30" FontWeight="Bold"
                       FontFamily="{StaticResource MonoFont}"/>
            <TextBlock Text="{Binding FiveHourResetText}" FontSize="11" Opacity="0.6"
                       VerticalAlignment="Bottom" Margin="10,0,0,6"/>
          </StackPanel>
          <ProgressBar Value="{Binding FiveHourPct, Mode=OneWay}" Maximum="100" Height="8"
                       Background="{DynamicResource ProgressTrackBrush}" Foreground="#5AAAFA" BorderThickness="0"/>
          <TextBlock Text="{Binding ExhaustionNote}" FontSize="10" Margin="0,5,0,0"
                     Foreground="{DynamicResource PredictionBrush}" FontWeight="SemiBold"
                     Style="{StaticResource HideWhenEmpty}"/>
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource Card}">
        <StackPanel>
          <TextBlock Text="주간 사용률" FontSize="12" Opacity="0.7"/>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="{Binding SevenDayPct, StringFormat={}{0:0}%}" FontSize="30" FontWeight="Bold"
                       FontFamily="{StaticResource MonoFont}"/>
            <TextBlock Text="{Binding SevenDayResetText}" FontSize="11" Opacity="0.6"
                       VerticalAlignment="Bottom" Margin="10,0,0,6"/>
          </StackPanel>
          <ProgressBar Value="{Binding SevenDayPct, Mode=OneWay}" Maximum="100" Height="8"
                       Background="{DynamicResource ProgressTrackBrush}" Foreground="#8A6CF0" BorderThickness="0"/>
        </StackPanel>
      </Border>

      <StackPanel Grid.Column="2" VerticalAlignment="Center">
        <Border Background="{DynamicResource BadgeBackgroundBrush}" CornerRadius="10" Padding="10,4" HorizontalAlignment="Right">
          <TextBlock Text="{Binding PlanBadge}" FontSize="11"/>
        </Border>
        <TextBlock Text="(stale)" FontSize="10" Foreground="#F0A030" HorizontalAlignment="Right" Margin="0,4,0,0"
                   Visibility="{Binding IsStale, Converter={StaticResource BoolToVis}}"/>
        <Button x:Name="SettingsButton" Content="설정" Margin="0,8,0,0"
                Style="{StaticResource AppButton}" HorizontalAlignment="Right" MinWidth="76"/>
      </StackPanel>
    </Grid>

    <!-- 현재 프로젝트 -->
    <StackPanel Grid.Row="1" Margin="0,14,0,0">
      <TextBlock Text="현재 사용 중인 프로젝트" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
      <ItemsControl ItemsSource="{Binding LiveSessions}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel/>
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <!-- 암시적 TextBlock 스타일은 DataTemplate 경계를 넘지 않으므로 명시 지정 (가시성 버그 수정) -->
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="10,5" Margin="0,0,8,6"
                    ToolTip="{Binding FullPath}">
              <StackPanel Orientation="Horizontal">
                <Ellipse Width="7" Height="7" Fill="#4CC38A" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="{Binding ProjectName}" FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Status}" FontSize="10" Opacity="0.65" Margin="6,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Text="실행 중인 Claude Code 세션이 없습니다" FontSize="11" Opacity="0.5"
                 Visibility="{Binding HasNoLiveSessions, Converter={StaticResource BoolToVis}}"/>
    </StackPanel>

    <!-- 기간 세그먼트 + 합계 -->
    <Grid Grid.Row="2" Margin="0,14,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="{DynamicResource SegmentTrackBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
              CornerRadius="8" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal">
          <RadioButton x:Name="DailyToggle" Content="일간" IsChecked="True" Style="{StaticResource SegmentRadio}"/>
          <RadioButton x:Name="WeeklyToggle" Content="주간" Style="{StaticResource SegmentRadio}"/>
          <RadioButton x:Name="MonthlyToggle" Content="월간" Style="{StaticResource SegmentRadio}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource Card}">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="총 토큰 " Opacity="0.7" FontSize="12" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding PeriodTotalTokensText}" FontWeight="Bold" FontSize="15"
                     FontFamily="{StaticResource MonoFont}"/>
        </StackPanel>
      </Border>
      <Border Grid.Column="3" Style="{StaticResource Card}" Margin="0">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="총 비용 " Opacity="0.7" FontSize="12" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding PeriodTotalCostText}" FontWeight="Bold" FontSize="15" Foreground="#7BD88F"
                     FontFamily="{StaticResource MonoFont}"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- 차트 (배경은 창 배경과 동일 톤) -->
    <lvc:CartesianChart x:Name="UsageChart"
                        Grid.Row="3"
                        Background="{DynamicResource ChartBackgroundBrush}"
                        Series="{Binding Series}"
                        XAxes="{Binding XAxes}"
                        YAxes="{Binding YAxes}"
                        LegendTextPaint="{Binding LegendTextPaint}"
                        LegendPosition="Top"/>

    <TextBlock Grid.Row="4" Text="{Binding CoverageNote}" FontSize="10" Opacity="0.5" Margin="0,6,0,0"/>
  </Grid>
</Window>
