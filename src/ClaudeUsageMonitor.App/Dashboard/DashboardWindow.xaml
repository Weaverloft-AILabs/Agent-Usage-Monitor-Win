<Window x:Class="ClaudeUsageMonitor.App.Dashboard.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:conv="clr-namespace:ClaudeUsageMonitor.App.Converters"
        Title="Agent Usage Monitor"
        Width="880" Height="720"
        MinWidth="720" MinHeight="520"
        Background="{DynamicResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <conv:PercentStarConverter x:Key="PercentStar"/>

    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>
    <Style x:Key="HideWhenEmpty" TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
      <Style.Triggers>
        <Trigger Property="Text" Value="">
          <Setter Property="Visibility" Value="Collapsed"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- eyebrow / section label (mono, coral) -->
    <Style x:Key="Eyebrow" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentButtonBrush}"/>
      <Setter Property="Opacity" Value="0.95"/>
    </Style>
    <Style x:Key="MutedLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
      <Setter Property="FontSize" Value="10.5"/>
      <Setter Property="Opacity" Value="0.5"/>
    </Style>

    <!-- icon toolbar buttons -->
    <Style x:Key="IconButton" TargetType="Button">
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="30"/>
      <Setter Property="Margin" Value="6,0,0,0"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="8" SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="IconButtonAccent" TargetType="Button" BasedOn="{StaticResource IconButton}">
      <Setter Property="Background" Value="{DynamicResource AccentButtonBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                    CornerRadius="8" SnapsToDevicePixels="True">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- hero gauge card (subtle vertical gradient) -->
    <Style x:Key="GaugeCard" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource GaugeCardBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="14,10"/>
    </Style>

    <!-- rounded meter -->
    <Style x:Key="GaugeBar" TargetType="ProgressBar">
      <Setter Property="Height" Value="9"/>
      <Setter Property="Background" Value="{DynamicResource GaugeTrackBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Grid>
              <Border CornerRadius="5" Background="{TemplateBinding Background}"/>
              <Border x:Name="PART_Track"/>
              <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                      CornerRadius="5" Background="{TemplateBinding Foreground}"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- KPI stat tile -->
    <Style x:Key="StatTile" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding" Value="12,7"/>
      <Setter Property="MinWidth" Value="138"/>
      <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <!-- chart / section card -->
    <Style x:Key="ChartCard" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource ChartCardBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ChartCardBorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="15,12"/>
      <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>
    <Style x:Key="CardTitle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
  </Window.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,14,16,16">
    <StackPanel>

      <!-- ===== header bar ===== -->
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <TextBlock Text="USAGE" Style="{StaticResource Eyebrow}"/>
          <TextBlock Text="Claude Code 사용량" FontSize="15" FontWeight="SemiBold" Margin="0,1,0,0"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Border Background="{DynamicResource BadgeBackgroundBrush}" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
            <TextBlock Text="{Binding PlanBadge}" FontSize="11" Foreground="{DynamicResource TextPrimaryBrush}"/>
          </Border>
          <TextBlock Text="●" FontSize="10" Foreground="#F0A030" VerticalAlignment="Center" Margin="6,0,0,0"
                     ToolTip="캐시된(stale) 데이터" Visibility="{Binding IsStale, Converter={StaticResource BoolToVis}}"/>
          <!-- 아이콘: 24x24 고정 Canvas를 Viewbox로 담아 버튼 정중앙에 일관 배치 -->
          <Button x:Name="RefreshButton" Style="{StaticResource IconButtonAccent}" ToolTip="새로고침">
            <Viewbox Width="16" Height="16">
              <Canvas Width="24" Height="24">
                <Path Data="M20.49 15a9 9 0 1 1-2.12-9.36L23 10 M23 4v6h-6" Stroke="White" StrokeThickness="2"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Button x:Name="SettingsButton" Style="{StaticResource IconButton}" ToolTip="설정">
            <Viewbox Width="16" Height="16">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource TextPrimaryBrush}"
                      Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.48.48 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
              </Canvas>
            </Viewbox>
          </Button>
          <Button x:Name="InquiryButton" Style="{StaticResource IconButton}" ToolTip="문의하기">
            <Viewbox Width="16" Height="16">
              <Canvas Width="24" Height="24">
                <Path Data="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2z M22 6l-10 7L2 6"
                      Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="2"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
              </Canvas>
            </Viewbox>
          </Button>
        </StackPanel>
      </Grid>

      <!-- ===== hero gauges ===== -->
      <Grid Margin="0,0,0,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource GaugeCard}" Margin="0,0,7,0">
          <StackPanel>
            <Grid>
              <TextBlock Text="5시간 사용률" FontSize="11" Opacity="0.62" HorizontalAlignment="Left"/>
              <TextBlock Text="{Binding FiveHourResetText}" FontSize="10" Opacity="0.42"
                         FontFamily="{StaticResource MonoFont}" HorizontalAlignment="Right"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,1,0,6">
              <TextBlock Text="{Binding FiveHourPct, StringFormat={}{0:0}}" FontSize="28" FontWeight="Bold"
                         FontFamily="{StaticResource MonoFont}" LineHeight="28"/>
              <TextBlock Text="%" FontSize="14" FontWeight="SemiBold" Opacity="0.6"
                         VerticalAlignment="Bottom" Margin="2,0,0,4"/>
            </StackPanel>
            <Grid Height="7">
              <ProgressBar Value="{Binding FiveHourPct, Mode=OneWay}" Maximum="100" Height="7"
                           Style="{StaticResource GaugeBar}" Foreground="#5AAAFA"/>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="{Binding WarnThresholdPct, Converter={StaticResource PercentStar}}"/>
                  <ColumnDefinition Width="{Binding WarnThresholdPct, Converter={StaticResource PercentStar}, ConverterParameter=rest}"/>
                </Grid.ColumnDefinitions>
                <Rectangle Grid.Column="1" Width="2" Height="12" RadiusX="1" RadiusY="1"
                           HorizontalAlignment="Left" VerticalAlignment="Center"
                           Fill="{DynamicResource TextPrimaryBrush}" Opacity="0.7"
                           ToolTip="{Binding WarnThresholdPct, StringFormat=경고 임계값 {0:0}%}"/>
              </Grid>
            </Grid>
            <TextBlock Text="{Binding ExhaustionNote}" FontSize="9.5" Margin="0,6,0,0"
                       Foreground="{DynamicResource PredictionBrush}" FontWeight="SemiBold"
                       Style="{StaticResource HideWhenEmpty}"/>
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Style="{StaticResource GaugeCard}" Margin="7,0,0,0">
          <StackPanel>
            <Grid>
              <TextBlock Text="주간 사용률" FontSize="11" Opacity="0.62" HorizontalAlignment="Left"/>
              <TextBlock Text="{Binding SevenDayResetText}" FontSize="10" Opacity="0.42"
                         FontFamily="{StaticResource MonoFont}" HorizontalAlignment="Right"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,1,0,6">
              <TextBlock Text="{Binding SevenDayPct, StringFormat={}{0:0}}" FontSize="28" FontWeight="Bold"
                         FontFamily="{StaticResource MonoFont}" LineHeight="28"/>
              <TextBlock Text="%" FontSize="14" FontWeight="SemiBold" Opacity="0.6"
                         VerticalAlignment="Bottom" Margin="2,0,0,4"/>
            </StackPanel>
            <Grid Height="7">
              <ProgressBar Value="{Binding SevenDayPct, Mode=OneWay}" Maximum="100" Height="7"
                           Style="{StaticResource GaugeBar}" Foreground="#8A6CF0"/>
            </Grid>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ===== period + KPI tiles ===== -->
      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{DynamicResource SegmentTrackBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                CornerRadius="9" VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <RadioButton x:Name="DailyToggle" Content="일간" IsChecked="True" Style="{StaticResource SegmentRadio}"/>
            <RadioButton x:Name="WeeklyToggle" Content="주간" Style="{StaticResource SegmentRadio}"/>
            <RadioButton x:Name="MonthlyToggle" Content="월간" Style="{StaticResource SegmentRadio}"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="2" Style="{StaticResource StatTile}">
          <StackPanel>
            <TextBlock Text="총 토큰" FontSize="10.5" Opacity="0.55"/>
            <TextBlock Text="{Binding PeriodTotalTokensText}" FontSize="18" FontWeight="Bold"
                       FontFamily="{StaticResource MonoFont}" Margin="0,2,0,0"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="3" Style="{StaticResource StatTile}">
          <StackPanel>
            <TextBlock Text="총 비용" FontSize="10.5" Opacity="0.55"/>
            <TextBlock Text="{Binding PeriodTotalCostText}" FontSize="18" FontWeight="Bold"
                       Foreground="{DynamicResource SuccessTextBrush}" FontFamily="{StaticResource MonoFont}" Margin="0,2,0,0"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ===== main token chart (single left axis) ===== -->
      <Border Style="{StaticResource ChartCard}">
        <StackPanel>
          <TextBlock Text="토큰 사용량 · 모델별 스택" Style="{StaticResource CardTitle}" Margin="0,0,0,4"/>
          <!-- 고정 높이 Grid로 래핑: hover 시 재측정용 Height 1px 바운스가 카드 밖 레이아웃을 밀지 않도록 클리핑 -->
          <Grid Height="248" ClipToBounds="True">
            <lvc:CartesianChart x:Name="UsageChart" Height="248"
                                Background="Transparent"
                                Series="{Binding Series}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"
                                LegendTextPaint="{Binding LegendTextPaint}"
                                TooltipTextPaint="{Binding TooltipTextPaint}"
                                TooltipBackgroundPaint="{Binding TooltipBackgroundPaint}"
                                TooltipPosition="Top"
                                LegendPosition="Top"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ===== cost sparkline (small multiple, single $ axis) ===== -->
      <Border Style="{StaticResource ChartCard}">
        <StackPanel>
          <Grid Margin="0,0,0,2">
            <TextBlock HorizontalAlignment="Left">
              <Run Text="비용 추이" FontSize="12" FontWeight="SemiBold"/><Run Text="  · USD" FontSize="11" Foreground="#8A8CA0"/>
            </TextBlock>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
              <Ellipse Width="8" Height="8" Fill="{DynamicResource SuccessTextBrush}" VerticalAlignment="Center"/>
              <TextBlock Text="비용($)" FontSize="11" Opacity="0.62" Margin="6,0,0,0"/>
            </StackPanel>
          </Grid>
          <Canvas x:Name="SparkCanvas" Height="88" Background="Transparent" ClipToBounds="True"/>
        </StackPanel>
      </Border>

      <!-- ===== model cost breakdown (100% share bar + rows) ===== -->
      <Border Style="{StaticResource ChartCard}"
              Visibility="{Binding HasBreakdown, Converter={StaticResource BoolToVis}}">
        <StackPanel>
          <TextBlock Text="{Binding PeriodScopeText, StringFormat=모델별 비용 · {0}}" Style="{StaticResource CardTitle}" Margin="0,0,0,8"/>
          <Grid x:Name="ShareBarHost" Height="16" Margin="0,0,0,12"/>
          <ItemsControl ItemsSource="{Binding ModelBreakdown}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="66"/>
                    <ColumnDefinition Width="42"/>
                  </Grid.ColumnDefinitions>
                  <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding Dot}" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                  <TextBlock Grid.Column="1" Text="{Binding Model}" FontSize="12"
                             Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="2" Text="{Binding TokensText}" FontSize="11.5" FontFamily="{StaticResource MonoFont}"
                             Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.55" VerticalAlignment="Center" Margin="0,0,14,0"/>
                  <TextBlock Grid.Column="3" Text="{Binding CostText}" FontSize="11.5" FontFamily="{StaticResource MonoFont}"
                             FontWeight="SemiBold" Foreground="{DynamicResource SuccessTextBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
                  <TextBlock Grid.Column="4" Text="{Binding ShareText}" FontSize="11" FontFamily="{StaticResource MonoFont}"
                             Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.42"
                             HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <!-- ===== current projects ===== -->
      <TextBlock Text="현재 사용 중인 프로젝트" FontSize="11.5" FontWeight="SemiBold"
                 Foreground="{DynamicResource TextPrimaryBrush}" Opacity="0.9" Margin="2,2,0,8"/>
      <ItemsControl ItemsSource="{Binding LiveSessions}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="10,4" Margin="0,0,8,7" ToolTip="{Binding FullPath}">
              <StackPanel Orientation="Horizontal">
                <Ellipse Width="7" Height="7" Fill="#4CC38A" VerticalAlignment="Center" Margin="0,0,7,0"/>
                <TextBlock Text="{Binding ProjectName}" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Status}" FontSize="10" Opacity="0.45" Margin="7,0,0,0"
                           VerticalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
      <TextBlock Text="실행 중인 Claude Code 세션이 없습니다" FontSize="11" Opacity="0.42" Margin="2,0,0,0"
                 Visibility="{Binding HasNoLiveSessions, Converter={StaticResource BoolToVis}}"/>

      <TextBlock Text="{Binding CoverageNote}" Style="{StaticResource MutedLabel}" Margin="2,14,0,0"
                 TextWrapping="Wrap"/>
    </StackPanel>
  </ScrollViewer>
</Window>
