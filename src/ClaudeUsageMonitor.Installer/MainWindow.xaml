<Window x:Class="ClaudeUsageMonitor.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Agent Usage Monitor 설치"
        Width="560" Height="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Malgun Gothic"
        PreviewKeyDown="OnPreviewKeyDown">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- 디자인 카드 토큰 (다크 고정 — 인스톨러는 테마 전환 없음) -->
    <SolidColorBrush x:Key="InkBrush" Color="#1E1F29"/>
    <SolidColorBrush x:Key="CardBrush" Color="#2A2C3A"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#353849"/>
    <SolidColorBrush x:Key="TextBrush" Color="#E8E8F0"/>
    <SolidColorBrush x:Key="TextDimBrush" Color="#94E8E8F0"/>
    <SolidColorBrush x:Key="CoralBrush" Color="#D97757"/>
    <SolidColorBrush x:Key="CoralHoverBrush" Color="#C4674A"/>
    <SolidColorBrush x:Key="CoralPressBrush" Color="#A85842"/>
    <SolidColorBrush x:Key="BlueBrush" Color="#5AAAFA"/>
    <SolidColorBrush x:Key="WarnBrush" Color="#F0A030"/>
    <SolidColorBrush x:Key="ErrBrush" Color="#E0503C"/>
    <SolidColorBrush x:Key="OkBrush" Color="#7BD88F"/>
    <SolidColorBrush x:Key="GaugeTrackBrush" Color="#2EFFFFFF"/>
    <SolidColorBrush x:Key="PendingDotBrush" Color="#4A4E63"/>
    <FontFamily x:Key="MonoFont">Cascadia Mono, Consolas, Courier New</FontFamily>

    <!-- 액센트 버튼 (radius 8 · hover/press 코랄 단계 · Tab 포커스 링 코랄 1.5px) -->
    <Style x:Key="AccentButton" TargetType="Button">
      <Setter Property="Foreground" Value="#FFFFFF"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="26,0"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Ring" CornerRadius="10" BorderThickness="1.5" BorderBrush="Transparent" Padding="1">
              <Border x:Name="Chrome" CornerRadius="8" Height="42" Background="{StaticResource CoralBrush}"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource CoralHoverBrush}"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource CoralPressBrush}"/>
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource CoralBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 고스트 버튼 (투명 배경 · 보더 1px #353849 · hover #2A2C3A) -->
    <Style x:Key="GhostButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="22,0"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Ring" CornerRadius="10" BorderThickness="1.5" BorderBrush="Transparent" Padding="1">
              <Border x:Name="Chrome" CornerRadius="8" Height="42" Background="Transparent"
                      BorderThickness="1" BorderBrush="{StaticResource CardBorderBrush}"
                      Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource CardBrush}"/>
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Ring" Property="BorderBrush" Value="{StaticResource CoralBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 커스텀 크롬 ✕ (46×32 히트 · hover #2A2C3A · 진행 중 비활성 · 탭 순회 제외 — Esc/마우스로 충분) -->
    <Style x:Key="CloseButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="IsTabStop" Value="False"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Chrome" Width="46" Height="32" Background="Transparent">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource CardBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.35"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding State}" Value="Progress">
          <Setter Property="IsEnabled" Value="False"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <!-- 단계 타임라인: 도트 8px · 활성 코랄+글로우 · 완료 ✓ · 커넥터 1px #353849 -->
    <Style x:Key="StepDot" TargetType="Ellipse">
      <Setter Property="Width" Value="8"/>
      <Setter Property="Height" Value="8"/>
      <Setter Property="Fill" Value="{StaticResource PendingDotBrush}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="Active">
          <Setter Property="Fill" Value="{StaticResource CoralBrush}"/>
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#D97757" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
            </Setter.Value>
          </Setter>
          <!-- 1.6s 펄스 — AV 홀드 대기 중 "살아있음" 신호 (카드 모션 스펙) -->
          <DataTrigger.EnterActions>
            <BeginStoryboard x:Name="ActiveDotPulse">
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.55"
                                 Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <StopStoryboard BeginStoryboardName="ActiveDotPulse"/>
          </DataTrigger.ExitActions>
        </DataTrigger>
        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="Done">
          <Setter Property="Visibility" Value="Collapsed"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="StepCheck" TargetType="TextBlock">
      <Setter Property="Text" Value="✓"/>
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Visibility" Value="Collapsed"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="Done">
          <Setter Property="Visibility" Value="Visible"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="StepLabel" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11.5"/>
      <Setter Property="Margin" Value="6,0,0,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
      <Setter Property="Opacity" Value="0.75"/>
      <Style.Triggers>
        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="Active">
          <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
          <Setter Property="Opacity" Value="1"/>
        </DataTrigger>
        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=StackPanel}}" Value="Done">
          <Setter Property="Opacity" Value="1"/>
        </DataTrigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="StepConnector" TargetType="Border">
      <Setter Property="Width" Value="16"/>
      <Setter Property="Height" Value="1"/>
      <Setter Property="Background" Value="{StaticResource CardBorderBrush}"/>
      <Setter Property="Margin" Value="8,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- 링크 (blue — 코랄은 액션 전용) -->
    <Style TargetType="Hyperlink">
      <Setter Property="Foreground" Value="{StaticResource BlueBrush}"/>
      <Setter Property="TextDecorations" Value="Underline"/>
    </Style>
  </Window.Resources>

  <Border CornerRadius="10" Background="{StaticResource InkBrush}"
          BorderBrush="{StaticResource CardBrush}" BorderThickness="1">
    <Grid>
      <Grid.Clip>
        <RectangleGeometry RadiusX="10" RadiusY="10" Rect="0,0,558,398"/>
      </Grid.Clip>

      <!-- 코랄 글로우 (splash와 동일 계열: 360×360 @ (-120,-160), α.20) -->
      <Ellipse Width="360" Height="360" HorizontalAlignment="Left" VerticalAlignment="Top"
               Margin="-120,-160,0,0" IsHitTestVisible="False">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="#33D97757" Offset="0"/>
            <GradientStop Color="#00D97757" Offset="0.62"/>
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>

      <!-- 상단 40px 드래그 영역 -->
      <Border Height="40" VerticalAlignment="Top" Background="Transparent"
              MouseLeftButtonDown="OnDragStrip"/>

      <!-- 커스텀 크롬 ✕ -->
      <Button Style="{StaticResource CloseButton}" Content="✕" Click="OnCloseClick"
              HorizontalAlignment="Right" VerticalAlignment="Top"
              AutomationProperties.Name="닫기"/>

      <!-- 타이틀/메타 (splash와 동일 위치 계열) -->
      <TextBlock Text="Agent Usage Monitor" FontSize="24" FontWeight="Bold" Foreground="#EEEEEE"
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="36,44,0,0"/>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top"
                  Margin="36,84,0,0">
        <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1" CornerRadius="6" Padding="8,2">
          <TextBlock Text="{Binding VersionText}" FontFamily="{StaticResource MonoFont}"
                     FontSize="11.5" Foreground="{StaticResource TextBrush}"/>
        </Border>
        <TextBlock Text="WeaverLoft inc. AILabs" FontSize="12" Foreground="{StaticResource TextDimBrush}"
                   VerticalAlignment="Center" Margin="10,0,0,0"/>
      </StackPanel>

      <!-- 본문 (좌우 36 · top 132 — 4상태가 같은 컬럼 라인 공유) -->
      <Grid Margin="36,132,36,56">

        <!-- STATE: 준비 -->
        <StackPanel VerticalAlignment="Top">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Ready">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <TextBlock Text="Claude Code 사용량을 작업표시줄에서 실시간으로."
                     FontSize="13" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,6"/>
          <TextBlock Text="{Binding InstallLocationText}" FontFamily="{StaticResource MonoFont}"
                     FontSize="11.5" Foreground="{StaticResource TextDimBrush}" Margin="0,0,0,26"/>
          <Button Content="지금 설치" Style="{StaticResource AccentButton}"
                  Command="{Binding InstallCommand}" HorizontalAlignment="Left" IsDefault="True"/>
        </StackPanel>

        <!-- STATE: 진행 -->
        <StackPanel VerticalAlignment="Top">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Progress">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <Grid Margin="0,0,0,10">
            <TextBlock Text="{Binding HeadlineText}" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" HorizontalAlignment="Left"/>
            <TextBlock Text="{Binding ProgressValueText}" FontFamily="{StaticResource MonoFont}"
                       FontSize="15" FontWeight="Bold" Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Right"/>
          </Grid>
          <Border Height="10" CornerRadius="5" Background="{StaticResource GaugeTrackBrush}">
            <Border HorizontalAlignment="Left" CornerRadius="5" Background="{StaticResource BlueBrush}"
                    Width="{Binding GaugeWidth}"/>
          </Border>
          <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" Tag="{Binding DownloadStepState}">
              <Ellipse Style="{StaticResource StepDot}"/>
              <TextBlock Style="{StaticResource StepCheck}"/>
              <TextBlock Text="다운로드" Style="{StaticResource StepLabel}"/>
            </StackPanel>
            <Border Style="{StaticResource StepConnector}"/>
            <StackPanel Orientation="Horizontal" Tag="{Binding ScanStepState}">
              <Ellipse Style="{StaticResource StepDot}"/>
              <TextBlock Style="{StaticResource StepCheck}"/>
              <TextBlock Text="보안 검사" Style="{StaticResource StepLabel}"/>
            </StackPanel>
            <Border Style="{StaticResource StepConnector}"/>
            <StackPanel Orientation="Horizontal" Tag="{Binding InstallStepState}">
              <Ellipse Style="{StaticResource StepDot}"/>
              <TextBlock Style="{StaticResource StepCheck}"/>
              <TextBlock Text="설치" Style="{StaticResource StepLabel}"/>
            </StackPanel>
            <Border Style="{StaticResource StepConnector}"/>
            <StackPanel Orientation="Horizontal" Tag="{Binding CompleteStepState}">
              <Ellipse Style="{StaticResource StepDot}"/>
              <TextBlock Style="{StaticResource StepCheck}"/>
              <TextBlock Text="완료" Style="{StaticResource StepLabel}"/>
            </StackPanel>
          </StackPanel>
          <!-- Grid(Auto,*) — 가로 StackPanel에서는 TextWrapping이 동작하지 않음 (무한 폭 측정) -->
          <Grid Margin="0,18,0,0"
                Visibility="{Binding ShowSlowHint, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="⚠" FontSize="11.5" Foreground="{StaticResource WarnBrush}"
                       Margin="0,0,7,0" VerticalAlignment="Top"/>
            <TextBlock Grid.Column="1"
                       Text="보안 소프트웨어 검사로 1분 이상 걸릴 수 있습니다 — 창을 닫지 말고 기다려 주세요."
                       FontSize="11.5" Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap"/>
          </Grid>
        </StackPanel>

        <!-- STATE: 완료 -->
        <StackPanel VerticalAlignment="Top">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Done">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
            <Grid Width="34" Height="34" VerticalAlignment="Top">
              <Ellipse Fill="#247BD88F"/>
              <TextBlock Text="✓" FontSize="17" FontWeight="Bold" Foreground="{StaticResource OkBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <StackPanel Margin="12,0,0,0">
              <TextBlock Text="설치가 끝났습니다" FontSize="17" FontWeight="SemiBold"
                         Foreground="{StaticResource TextBrush}"/>
              <TextBlock Text="위젯이 작업표시줄에 표시됩니다. 우클릭으로 메뉴를 열 수 있습니다."
                         FontSize="12" Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0"/>
            </StackPanel>
          </StackPanel>
          <Border Height="10" CornerRadius="5" Background="{StaticResource GaugeTrackBrush}" Margin="0,0,0,22">
            <Border CornerRadius="5" Background="{StaticResource BlueBrush}"/>
          </Border>
          <Button Content="시작하기" Style="{StaticResource AccentButton}"
                  Command="{Binding LaunchCommand}" HorizontalAlignment="Left" IsDefault="True"/>
        </StackPanel>

        <!-- STATE: 오류 -->
        <StackPanel VerticalAlignment="Top">
          <StackPanel.Style>
            <Style TargetType="StackPanel">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding State}" Value="Error">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </StackPanel.Style>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <Grid Width="34" Height="34" VerticalAlignment="Top">
              <Ellipse Fill="#24E0503C"/>
              <TextBlock Text="✕" FontSize="17" FontWeight="Bold" Foreground="{StaticResource ErrBrush}"
                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
            <StackPanel Margin="12,0,0,0">
              <TextBlock Text="설치를 완료하지 못했습니다" FontSize="17" FontWeight="SemiBold"
                         Foreground="{StaticResource TextBrush}"/>
              <TextBlock Text="{Binding ErrorAdvice}" FontSize="12"
                         Foreground="{StaticResource TextDimBrush}" Margin="0,2,0,0"/>
            </StackPanel>
          </StackPanel>
          <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                  BorderThickness="1" CornerRadius="8" Padding="12,10" Margin="0,0,0,18">
            <TextBlock Text="{Binding ErrorDetail}" FontFamily="{StaticResource MonoFont}" FontSize="11"
                       Foreground="{StaticResource TextDimBrush}" TextWrapping="Wrap"/>
          </Border>
          <Grid>
            <StackPanel Orientation="Horizontal">
              <Button Content="다시 시도" Style="{StaticResource AccentButton}"
                      Command="{Binding InstallCommand}" IsDefault="True"/>
              <Button Content="로그 열기" Style="{StaticResource GhostButton}"
                      Command="{Binding OpenLogCommand}" Margin="10,0,0,0"/>
            </StackPanel>
            <TextBlock VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12">
              <Hyperlink Command="{Binding OpenReleasesCommand}">GitHub에서 수동 다운로드</Hyperlink>
            </TextBlock>
          </Grid>
        </StackPanel>
      </Grid>

      <!-- 푸터 — AGPL §5(d), 전 상태 동일 (진행 중엔 우측에 취소) -->
      <Grid VerticalAlignment="Bottom" Margin="36,0,36,18">
        <TextBlock FontSize="10" Foreground="{StaticResource TextDimBrush}" HorizontalAlignment="Left">
          <Run Text="© 2026 WeaverLoft inc. AILabs · GNU AGPL-3.0 · 소스: "/><Hyperlink Command="{Binding OpenRepoCommand}">GitHub</Hyperlink>
        </TextBlock>
        <TextBlock FontSize="12" HorizontalAlignment="Right"
                   Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}">
          <Hyperlink Command="{Binding CancelCommand}">취소</Hyperlink>
        </TextBlock>
      </Grid>
    </Grid>
  </Border>
</Window>
